{
  "name": "design-studio",
  "version": "1.0.0",
  "description": "Сайт дизайн-студии — 11ty + vanilla CSS + vanilla JS",
  "scripts": {
    "dev": "eleventy --config=eleventy.config.cjs --serve --watch",
    "build": "eleventy --config=eleventy.config.cjs",
    "clean": "rm -rf _site",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "wrangler": "^4.71.0"
  }
}
