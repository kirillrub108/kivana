---
layout: layouts/case.njk
pagination:
  data: cases
  size: 1
  alias: caseItem
permalink: /work/{{ caseItem.slug }}/
eleventyComputed:
  pageTitle: "{{ caseItem.title }}"
  metaDescription: "{{ caseItem.challenge }}"
---

{% set allCases = cases %}
{% set currentIndex = 0 %}
{% for c in allCases %}
  {% if c.slug == caseItem.slug %}
    {% set currentIndex = loop.index0 %}
  {% endif %}
{% endfor %}

{# Case hero — только заголовок и теги #}
<section style="padding-top: var(--space-12); padding-bottom: var(--space-6)">
  <div class="container">
    <a href="/work/" class="back-link">← Все проекты</a>
    <div class="case-hero reveal">
      <h1 class="case-hero__title">{{ caseItem.title }}</h1>
      <div class="case-hero__meta">
        <span>{{ caseItem.client }}</span>
        <span>·</span>
        <span>{{ caseItem.year }}</span>
        <span>·</span>
        {% for tag in caseItem.tags %}
          <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# Image gallery — сразу после заголовка #}
<section style="padding-bottom: var(--space-12)">
  <div class="container">
    {% if caseItem.images and caseItem.images.length %}
      <div class="case-gallery reveal">
        {% for img in caseItem.images %}
        <img
          class="case-gallery__img{% if loop.first %} case-gallery__img--hero{% endif %}"
          src="{{ img }}"
          alt="{{ caseItem.title }} — {{ loop.index }}"
          loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
        >
        {% endfor %}
      </div>
    {% else %}
      <div class="reveal">
        <div class="gallery__item mb-8" style="background-color: {{ caseItem.color }}; aspect-ratio: 16/9;">Изображение проекта</div>
      </div>
      <div class="grid grid--2 reveal" style="--delay: 100ms">
        <div class="gallery__item" style="background-color: {{ caseItem.color }}; opacity: 0.8;">Детали</div>
        <div class="gallery__item" style="background-color: {{ caseItem.color }}; opacity: 0.6;">Детали</div>
      </div>
    {% endif %}
  </div>
</section>

{# Overview: Challenge + Solution #}
<section class="section--sm">
  <div class="container">
    <div class="grid grid--2 reveal">
      <div>
        <h2 class="text-2xl mb-4">Задача</h2>
        <p class="text-secondary" style="line-height: var(--leading-normal)">{{ caseItem.challenge }}</p>
      </div>
      <div>
        <h2 class="text-2xl mb-4">Решение</h2>
        <p class="text-secondary" style="line-height: var(--leading-normal)">{{ caseItem.solution }}</p>
      </div>
    </div>
  </div>
</section>

{# Results / Metrics #}
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <h2 class="section-header__title">Результаты</h2>
    </div>
    <div class="grid grid--3 reveal" style="--delay: 80ms">
      {% for m in caseItem.metrics %}
      <div class="metric">
        <div class="metric__value">{{ m.value }}</div>
        <div class="metric__label">{{ m.label }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# Next case #}
{% set nextIndex = currentIndex + 1 %}
{% if nextIndex >= allCases.length %}
  {% set nextIndex = 0 %}
{% endif %}
{% set nextCase = allCases[nextIndex] %}

<section class="section--sm">
  <div class="container">
    <a href="/work/{{ nextCase.slug }}/" class="next-case reveal">
      <div class="next-case__label">Следующий проект</div>
      <div class="next-case__title">{{ nextCase.title }}</div>
    </a>
  </div>
</section>

{# CTA #}
{% include "partials/cta-block.njk" %}

{# Lightbox #}
{% if caseItem.images and caseItem.images.length %}
<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Просмотр изображения">
  <div class="lightbox__backdrop"></div>
  <button class="lightbox__close" aria-label="Закрыть">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <button class="lightbox__btn lightbox__btn--prev" aria-label="Предыдущее">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>
  <div class="lightbox__stage">
    <img class="lightbox__img" src="" alt="">
  </div>
  <button class="lightbox__btn lightbox__btn--next" aria-label="Следующее">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>
  <div class="lightbox__counter"></div>
</div>
{% endif %}
