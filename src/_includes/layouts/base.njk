<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if customTitle %}{{ customTitle }}{% else %}{{ pageTitle }}{% if pageTitle %} — {% endif %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ metaDescription or site.description }}">
  
  <!-- Yandex Webmaster -->
  <meta name="yandex-verification" content="1d22179c064b27da" />

  <!-- Favicon -->
  <link rel="apple-touch-icon" sizes="180x180" href="./assets/images/favicon/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="./assets/images/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="./assets/images/favicon/favicon-16x16.png">
  <link rel="manifest" href="./assets/images/favicon/site.webmanifest">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ pageTitle }}{% if pageTitle %} — {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ metaDescription or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  {% include "partials/header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/main.js" type="module"></script>
</body>
</html>
